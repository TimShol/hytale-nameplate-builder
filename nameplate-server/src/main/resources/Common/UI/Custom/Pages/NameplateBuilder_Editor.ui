          // Section 6b: Chain Settings Content
          Group #ChainSettingsContent {
            LayoutMode: TopScrolling;
            ScrollbarStyle: (Spacing: 8, Size: 4, Background: #2a2610, Handle: #8b7a3a, HoveredHandle: #a08840, DraggedHandle: #b89848);
            FlexWeight: 1;
            Visible: false;
            Padding: (Left: 24, Top: 12);
            KeepScrollPosition: true;

            Label {
              Text: "CHAIN SETTINGS";
              Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
              Anchor: (Height: 24, Bottom: 12);
            }

            Label #AdminDisabledNotice {
              Text: "";
              Style: (TextColor: #c94c4c, FontSize: 13, RenderBold: true);
              Anchor: (Height: 20, Bottom: 12);
              Visible: false;
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 4);

              Label #ChainEnabledLabel {
                Text: "NPC Nameplates";
                Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
                Anchor: (Width: 300, Height: 28);
              }

              ToggleButton #ChainEnabledToggle {
                Anchor: (Width: 50, Height: 28);
                IsChecked: false;
                Background: (Color: #1e2530);
                TooltipText: "Enable or disable this nameplate chain type";
                TextTooltipShowDelay: 0.3;
                Label #ChainEnabledToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
              }
            }

            Label #ChainEnabledDesc {
              Text: "When disabled, no NPC nameplates are shown.";
              Style: (TextColor: #5a6d82, FontSize: 11);
              Anchor: (Height: 16, Bottom: 12);
            }

            Group #ModSectionSep { Anchor: (Height: 1, Bottom: 12); Background: (Color: #1a2840); Visible: false; }

