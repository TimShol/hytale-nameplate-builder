            }

            // Section 6a.2: Preview target bar and preview
            Group { Anchor: (Height: 1, Top: 10, Bottom: 10); Background: (Color: #1a2840); }

            Group #PreviewTargetBar {
              LayoutMode: Left;
              Anchor: (Height: 26);
              Visible: false;

              Group {
                FlexWeight: 1;
                Anchor: (Height: 26);
                LayoutMode: LeftScrolling;
                MouseWheelScrollBehaviour: HorizontalOnly;
                ScrollbarStyle: (Spacing: 2, Size: 3, Background: #2a2610, Handle: #8b7a3a, HoveredHandle: #a08840, DraggedHandle: #b89848);

                Group #PreviewTarget0 { Anchor: (Height: 26); Visible: false;
                  TextButton #PreviewTargetBtn0 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
                  TextButton #PreviewTargetBtn0Active { Text: ""; Anchor: (Height: 26); Style: @SubTabActiveStyle; Visible: false; }
                }
                Group { Anchor: (Width: 4); }
                Group #PreviewTarget1 { Anchor: (Height: 26); Visible: false;
                  TextButton #PreviewTargetBtn1 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
                  TextButton #PreviewTargetBtn1Active { Text: ""; Anchor: (Height: 26); Style: @SubTabActiveStyle; Visible: false; }
                }
                Group { Anchor: (Width: 4); }
                Group #PreviewTarget2 { Anchor: (Height: 26); Visible: false;
                  TextButton #PreviewTargetBtn2 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
                  TextButton #PreviewTargetBtn2Active { Text: ""; Anchor: (Height: 26); Style: @SubTabActiveStyle; Visible: false; }
                }
                Group { Anchor: (Width: 4); }
                Group #PreviewTarget3 { Anchor: (Height: 26); Visible: false;
                  TextButton #PreviewTargetBtn3 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
                  TextButton #PreviewTargetBtn3Active { Text: ""; Anchor: (Height: 26); Style: @SubTabActiveStyle; Visible: false; }
                }
                Group { Anchor: (Width: 4); }
                Group #PreviewTarget4 { Anchor: (Height: 26); Visible: false;
                  TextButton #PreviewTargetBtn4 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
                  TextButton #PreviewTargetBtn4Active { Text: ""; Anchor: (Height: 26); Style: @SubTabActiveStyle; Visible: false; }
                }
                Group { Anchor: (Width: 4); }
                Group #PreviewTarget5 { Anchor: (Height: 26); Visible: false;
                  TextButton #PreviewTargetBtn5 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
                  TextButton #PreviewTargetBtn5Active { Text: ""; Anchor: (Height: 26); Style: @SubTabActiveStyle; Visible: false; }
                }
                Group { Anchor: (Width: 4); }
                Group #PreviewTarget6 { Anchor: (Height: 26); Visible: false;
                  TextButton #PreviewTargetBtn6 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
