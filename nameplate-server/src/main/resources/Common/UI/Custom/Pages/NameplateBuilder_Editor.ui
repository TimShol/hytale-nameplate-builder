          // Section 7.3: Admin Settings Content
          Group #AdminSettingsContent {
            LayoutMode: TopScrolling;
            ScrollbarStyle: (Spacing: 8, Size: 4, Background: #2a2610, Handle: #8b7a3a, HoveredHandle: #a08840, DraggedHandle: #b89848);
            FlexWeight: 1;
            Visible: false;
            Padding: (Left: 24, Top: 12);
            KeepScrollPosition: true;

            Label { Text: "ADMIN SETTINGS"; Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); Anchor: (Height: 24, Bottom: 4); }
            Label { Text: "Configure server-wide nameplate settings."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 16, Bottom: 12); }

            Group { LayoutMode: Left; Anchor: (Height: 36, Bottom: 10);
              Label { Text: "Server Name:"; Style: (TextColor: #96a9be, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 130, Height: 36); }
              $C.@TextField #AdminServerNameField { Anchor: (Width: 330, Height: 34); PlaceholderText: "NameplateBuilder"; }
            }
            Label { Text: "Shown in the welcome message when players join. Leave blank for \"NameplateBuilder\"."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 20, Bottom: 20); }

            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 8);
              Label { Text: "Show Welcome Messages"; Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 300, Height: 28); }
              ToggleButton #AdminWelcomeToggle { Anchor: (Width: 50, Height: 28); IsChecked: false; Background: (Color: #1e2530);
                Label #AdminWelcomeToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
              }
            }
            Label { Text: "When enabled, all players see a welcome message on join. Players can still individually disable it."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 20, Bottom: 20); }

            Group { Anchor: (Height: 1, Bottom: 14); Background: (Color: #1a2840); }

            Label { Text: "KILLSWITCHES"; Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); Anchor: (Height: 20, Bottom: 8); }

            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
              Label { Text: "Master Enable"; Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 300, Height: 28); }
              ToggleButton #AdminMasterToggle { Anchor: (Width: 50, Height: 28); IsChecked: false; Background: (Color: #1e2530);
                Label #AdminMasterToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
              }
            }
            Label { Text: "When disabled, NameplateBuilder does nothing. No nameplates are created or updated."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 20, Bottom: 8); }

            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
              Label { Text: "Player Nameplates"; Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 300, Height: 28); }
              ToggleButton #AdminPlayerChainToggle { Anchor: (Width: 50, Height: 28); IsChecked: false; Background: (Color: #1e2530);
                Label #AdminPlayerChainToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
              }
            }
            Label { Text: "When disabled, no player nameplates are shown for any player."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 20, Bottom: 8); }

            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
              Label { Text: "NPC Nameplates"; Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 300, Height: 28); }
              ToggleButton #AdminNpcChainToggle { Anchor: (Width: 50, Height: 28); IsChecked: false; Background: (Color: #1e2530);
                Label #AdminNpcChainToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
              }
            }
            Label { Text: "When disabled, no NPC nameplates are shown for any entity."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 20, Bottom: 8); }

            Group { Anchor: (Height: 1, Top: 8, Bottom: 14); Background: (Color: #1a2840); }

            Label { Text: "WORLD KILLSWITCHES"; Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); Anchor: (Height: 20, Bottom: 4); }
            Label { Text: "Disabled worlds/instances will not show nameplates for any player."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 16, Bottom: 8); }

            Group #AdminWorldsContainer { LayoutMode: Left; Anchor: (Height: 220);
              Group { FlexWeight: 1; LayoutMode: Top;
                Label { Text: "Worlds"; Style: (TextColor: #7a8a9e, FontSize: 13, RenderBold: true); Anchor: (Height: 18, Bottom: 4); }
                Group #AdminWorldRow0 { LayoutMode: Left; Anchor: (Height: 26, Bottom: 2); Visible: false;
                  Label #AdminWorldRow0Label { Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 26); }
                  ToggleButton #AdminWorldRow0Toggle { Anchor: (Width: 44, Height: 26); IsChecked: false; Background: (Color: #1e2530);
                    Label #AdminWorldRow0ToggleText { Style: (FontSize: 11, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
                  }
                }
                Group #AdminWorldRow1 { LayoutMode: Left; Anchor: (Height: 26, Bottom: 2); Visible: false;
                  Label #AdminWorldRow1Label { Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 26); }
                  ToggleButton #AdminWorldRow1Toggle { Anchor: (Width: 44, Height: 26); IsChecked: false; Background: (Color: #1e2530);
