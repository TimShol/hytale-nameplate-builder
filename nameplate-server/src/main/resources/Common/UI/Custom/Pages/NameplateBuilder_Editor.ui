                  LayoutMode: Left;
                  Anchor: (Width: 160, Height: 22, Top: 2);
                  Visible: false;
                  TextButton #WorldFirst { Text: "<<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
                  TextButton #WorldPrev { Text: "<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
                  Label #WorldPageLabel { Text: "1/1"; Style: (TextColor: #5a6d82, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); FlexWeight: 1; }
                  TextButton #WorldNext { Text: ">"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
