              }
            }
            Group #DisabledRow11 { LayoutMode: Left; Anchor: (Height: 118, Bottom: 6);
              Group #DisabledBlock44 { Anchor: (Width: 194, Height: 118, Right: 8); Background: (Color: #3d2020); LayoutMode: Top; Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8); Visible: false;
                Label #DisabledBlock44Label { Text: ""; Style: (TextColor: #e2e8f0, FontSize: 14, RenderBold: true); Anchor: (Height: 20, Bottom: 2); }
                Label #DisabledBlock44Sub { Text: ""; Style: (TextColor: #96a9be, FontSize: 11); Anchor: (Height: 16, Bottom: 2); }
                Label #DisabledBlock44Author { Text: ""; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 16, Bottom: 4); }
                Group #DisabledBlock44ExampleBar { Anchor: (Height: 18); Background: (Color: #2a1010); Padding: (Left: 8, Right: 8, Top: 2, Bottom: 2); Visible: false;
                  Label #DisabledBlock44Example { Text: ""; Style: (TextColor: #c94c4c, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }
              }
              Group #DisabledBlock45 { Anchor: (Width: 194, Height: 118, Right: 8); Background: (Color: #3d2020); LayoutMode: Top; Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8); Visible: false;
                Label #DisabledBlock45Label { Text: ""; Style: (TextColor: #e2e8f0, FontSize: 14, RenderBold: true); Anchor: (Height: 20, Bottom: 2); }
                Label #DisabledBlock45Sub { Text: ""; Style: (TextColor: #96a9be, FontSize: 11); Anchor: (Height: 16, Bottom: 2); }
                Label #DisabledBlock45Author { Text: ""; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 16, Bottom: 4); }
                Group #DisabledBlock45ExampleBar { Anchor: (Height: 18); Background: (Color: #2a1010); Padding: (Left: 8, Right: 8, Top: 2, Bottom: 2); Visible: false;
                  Label #DisabledBlock45Example { Text: ""; Style: (TextColor: #c94c4c, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }
              }
              Group #DisabledBlock46 { Anchor: (Width: 194, Height: 118, Right: 8); Background: (Color: #3d2020); LayoutMode: Top; Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8); Visible: false;
                Label #DisabledBlock46Label { Text: ""; Style: (TextColor: #e2e8f0, FontSize: 14, RenderBold: true); Anchor: (Height: 20, Bottom: 2); }
                Label #DisabledBlock46Sub { Text: ""; Style: (TextColor: #96a9be, FontSize: 11); Anchor: (Height: 16, Bottom: 2); }
                Label #DisabledBlock46Author { Text: ""; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 16, Bottom: 4); }
                Group #DisabledBlock46ExampleBar { Anchor: (Height: 18); Background: (Color: #2a1010); Padding: (Left: 8, Right: 8, Top: 2, Bottom: 2); Visible: false;
                  Label #DisabledBlock46Example { Text: ""; Style: (TextColor: #c94c4c, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }
              }
              Group #DisabledBlock47 { Anchor: (Width: 194, Height: 118); Background: (Color: #3d2020); LayoutMode: Top; Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8); Visible: false;
                Label #DisabledBlock47Label { Text: ""; Style: (TextColor: #e2e8f0, FontSize: 14, RenderBold: true); Anchor: (Height: 20, Bottom: 2); }
                Label #DisabledBlock47Sub { Text: ""; Style: (TextColor: #96a9be, FontSize: 11); Anchor: (Height: 16, Bottom: 2); }
                Label #DisabledBlock47Author { Text: ""; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 16, Bottom: 4); }
                Group #DisabledBlock47ExampleBar { Anchor: (Height: 18); Background: (Color: #2a1010); Padding: (Left: 8, Right: 8, Top: 2, Bottom: 2); Visible: false;
                  Label #DisabledBlock47Example { Text: ""; Style: (TextColor: #c94c4c, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }
              }
            }
            Label #DisabledOverflow { Visible: false; Text: ""; Style: (FontSize: 11, TextColor: #5a6d82, HorizontalAlignment: Center); Anchor: (Height: 20); }
          }
        } // end #TabDisabled

      } // end #MainContent
    } // end #Content
  } // end DecoratedContainer

  // Section 9: Popups (siblings of DecoratedContainer, inside PageOverlay)

  // Section 9.0: Add Pattern Popup
  Group #PatternPopupOverlay {
    Anchor: (Width: 1080, Height: 780);
    Background: (Color: #00000080);
    Visible: false;

    Group {
      Anchor: (Width: 360, Height: 190);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 20, Bottom: 20);

      Label { Text: "Add Pattern"; Style: (TextColor: #96a9be, FontSize: 16, RenderBold: true, HorizontalAlignment: Center); Anchor: (Height: 26, Bottom: 8); }
      Label { Text: "Enter a Java regex pattern:"; Style: (TextColor: #5a6d82, FontSize: 12, HorizontalAlignment: Center); Anchor: (Height: 16, Bottom: 12); }

      $C.@TextField #PatternField { Anchor: (Height: 34, Bottom: 16); PlaceholderText: "e.g. Citizen.*"; }

      Group { LayoutMode: Left; Anchor: (Height: 36);
        TextButton #PatternCancel { Text: "Cancel"; Anchor: (Width: 100, Height: 36); Style: @PaginationButtonStyle; }
        Group { FlexWeight: 1; }
        TextButton #PatternConfirm { Text: "[+] Add Pattern"; Anchor: (Width: 150, Height: 36); Style: @SaveButtonStyle; }
      }
    }
  }

  // Section 9.1: Separator Popup
  Group #SepPopupOverlay {
    Anchor: (Width: 1080, Height: 780);
    Background: (Color: #00000080);
    Visible: false;

    Group {
      Anchor: (Width: 320, Height: 180);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

      Label { Text: "Edit Separator"; Style: (TextColor: #96a9be, FontSize: 16, RenderBold: true, HorizontalAlignment: Center); Anchor: (Height: 26, Bottom: 16); }
      Label { Text: "Enter the text to display between these two blocks:"; Style: (TextColor: #5a6d82, FontSize: 14, HorizontalAlignment: Center); Anchor: (Height: 20, Bottom: 12); }

      $C.@TextField #SepTextField { Anchor: (Height: 34, Bottom: 16); PlaceholderText: "Enter your separator..."; }

      Group { LayoutMode: Left; Anchor: (Height: 36);
        Group { FlexWeight: 1; }
        TextButton #SepCancel { Text: "Cancel"; Anchor: (Width: 100, Height: 36, Right: 10); Style: @PaginationButtonStyle; }
        TextButton #SepConfirm { Text: "Confirm"; Anchor: (Width: 100, Height: 36); Style: @SaveButtonStyle; }
      }
    }
  }

  // Section 9.2: Variant Popup
  Group #VariantPopupOverlay {
    Anchor: (Width: 1080, Height: 780);
    Background: (Color: #00000080);
    Visible: false;

    Group {
      Anchor: (Width: 320, Height: 520);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

      Label { Text: "Select Format"; Style: (TextColor: #96a9be, FontSize: 16, RenderBold: true, HorizontalAlignment: Center); Anchor: (Height: 26, Bottom: 12); }
      Label #VariantSegmentName { Text: ""; Style: (TextColor: #5a6d82, FontSize: 14, HorizontalAlignment: Center); Anchor: (Height: 20, Bottom: 12); }

      TextButton #Variant0 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }
      TextButton #Variant1 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }
      TextButton #Variant2 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }
      TextButton #Variant3 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }

      Group #PrefixSuffixSection {
        LayoutMode: Top;
        Visible: false;

        Group { Anchor: (Height: 1, Bottom: 8, Top: 8); Background: (Color: #2a3a4e); }
        Label { Text: "Prefix / Suffix"; Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true, HorizontalAlignment: Center); Anchor: (Height: 22, Bottom: 6); }
        Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
          Label { Text: "Before:"; Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 56, Height: 28); }
          $C.@TextField #PrefixField { Value: ""; Anchor: (Height: 28); FlexWeight: 1; PlaceholderText: "e.g. ["; }
        }
        Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
          Label { Text: "After:"; Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 56, Height: 28); }
          $C.@TextField #SuffixField { Value: ""; Anchor: (Height: 28); FlexWeight: 1; PlaceholderText: "e.g. ]"; }
        }
      }

      Group #BarCustomSection {
        LayoutMode: Top;
        Visible: false;

        Group { Anchor: (Height: 1, Bottom: 8, Top: 8); Background: (Color: #2a3a4e); }
        Label { Text: "Bar Style"; Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true, HorizontalAlignment: Center); Anchor: (Height: 22, Bottom: 6); }
        Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
          Label { Text: "Empty:"; Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center); Anchor: (Width: 56, Height: 28); }
          $C.@TextField #BarEmptyField { Value: ""; Anchor: (Height: 28); FlexWeight: 1; PlaceholderText: "-"; }
        }
      }

      Group { FlexWeight: 1; }

      TextButton #VariantCancel { Text: "Cancel"; Anchor: (Height: 36, Bottom: 4); Style: @PaginationButtonStyle; }
      TextButton #VariantConfirm { Text: "Confirm"; Anchor: (Height: 36); Style: @SaveButtonStyle; }
    }
  }

  // Section 9.3: NPC Picker Popup
  Group #NpcPickerPopup {
    Anchor: (Width: 1080, Height: 780);
    Background: (Color: #00000080);
    Visible: false;

    TextButton #NpcPickerBackdrop { Text: ""; Anchor: (Width: 1080, Height: 780); Style: @NpcPickerBackdropStyle; }

    Group {
      Anchor: (Width: 420, Height: 480);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 18, Right: 18, Top: 14, Bottom: 14);

      Label { Text: "Select NPC"; Style: (FontSize: 16, TextColor: #c8d6e5, RenderBold: true); Anchor: (Height: 26, Bottom: 8); }

      $C.@TextField #NpcPickerFilter { Anchor: (Height: 32, Bottom: 6); PlaceholderText: "Filter NPCs..."; }

      Group #NpcPickerRows {
        LayoutMode: Top;
        Anchor: (Height: 280);

        Group #NpcPickerRow0 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn0 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow1 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn1 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow2 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn2 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow3 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn3 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow4 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn4 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow5 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn5 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow6 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn6 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow7 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn7 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow8 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn8 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow9 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn9 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
      }

      Label #NpcPickerEmpty { Text: "No NPCs match filter."; Style: (FontSize: 13, TextColor: #5a6d82); Anchor: (Height: 18); Visible: false; }

      Group #NpcPickerPagination { LayoutMode: Left; Anchor: (Height: 22, Top: 4); Visible: false;
        Group { FlexWeight: 1; }
        TextButton #NpcPickerFirstPage { Text: "<<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
        TextButton #NpcPickerPrevPage { Text: "<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
        Label #NpcPickerPageInfo { Text: "1-10 of 100"; Style: (TextColor: #5a6d82, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100, Height: 22); }
        TextButton #NpcPickerNextPage { Text: ">"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
        TextButton #NpcPickerLastPage { Text: ">>"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
        Group { FlexWeight: 1; }
      }

      Group { LayoutMode: Left; Anchor: (Height: 22, Top: 8, Bottom: 6);
        Label { Text: "Selected: "; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); }
        Label #NpcPickerSelectedLabel { Text: "None"; Style: (FontSize: 13, TextColor: #4ade80, VerticalAlignment: Center); }
      }

      Group { LayoutMode: Left; Anchor: (Height: 34);
        TextButton #NpcPickerCancel { Text: "Cancel"; Anchor: (Height: 30); FlexWeight: 1; Style: @ResetButtonStyle; }
        TextButton #NpcPickerAddAllFiltered { Text: "Add All Filtered"; Anchor: (Height: 30, Left: 6); FlexWeight: 1; Style: @SaveButtonStyle; Visible: false; }
        TextButton #NpcPickerAdd { Text: "Add to Blacklist"; Anchor: (Height: 30, Left: 6); FlexWeight: 1; Style: @SaveButtonStyle; Visible: false; }
      }
    }
  }
}
