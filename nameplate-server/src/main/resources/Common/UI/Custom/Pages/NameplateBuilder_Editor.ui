          // Section 7.4: Admin Blacklist Content
          Group #AdminBlacklistContent {
            LayoutMode: Top;
            FlexWeight: 1;
            Visible: false;
            Padding: (Left: 8, Top: 12);

            Label { Text: "NPC BLACKLIST"; Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); Anchor: (Height: 24, Bottom: 4); }
            Label { Text: "Blacklisted NPCs will never receive nameplates from NameplateBuilder."; Style: (TextColor: #5a6d82, FontSize: 13); Anchor: (Height: 18, Bottom: 8); }

            // Pattern-based blacklist
            Label { Text: "PATTERNS (REGEX)"; Style: (TextColor: #96a9be, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); Anchor: (Height: 20, Bottom: 4); }
            Label { Text: "Patterns use Java regex. NPCs whose role name matches any pattern are blacklisted."; Style: (TextColor: #5a6d82, FontSize: 12); Anchor: (Height: 16, Bottom: 6); }

            Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 6);
              TextButton #PatternAddBtn { Text: "[+] Add Pattern"; Anchor: (Width: 180, Height: 30); Style: @SaveButtonStyle; TooltipText: "Add a regex pattern to blacklist matching NPCs"; TextTooltipShowDelay: 0.3; }
            }
            $C.@TextField #PatternFilterField { Anchor: (Height: 32, Bottom: 6); PlaceholderText: "Filter patterns..."; }

