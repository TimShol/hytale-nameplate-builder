            Label #PatternEmpty { Text: "No patterns defined."; Style: (TextColor: #5a6d82, FontSize: 12); Anchor: (Height: 18, Bottom: 8); }

            // Exact-match blacklist
            Label { Text: "EXACT MATCH"; Style: (TextColor: #96a9be, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); Anchor: (Height: 20, Bottom: 4); }
            Label { Text: "Individually blacklisted NPCs that will never receive nameplates."; Style: (TextColor: #5a6d82, FontSize: 11); Anchor: (Height: 16, Bottom: 6); }

            Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 6);
              TextButton #BlacklistAddBtn { Text: "[+] Add NPC(s)"; Anchor: (Width: 180, Height: 30); Style: @SaveButtonStyle; }
              Group { FlexWeight: 1; }
              TextButton #BlacklistRemoveFiltered { Text: "Remove Filtered"; Anchor: (Width: 150, Height: 30); Style: @ResetButtonStyle; Visible: false; }
            }

            $C.@TextField #BlacklistFilterField { Anchor: (Height: 32, Bottom: 6); PlaceholderText: "Filter NPCs..."; }

            Group #BlacklistList {
              LayoutMode: Top;

              Group #BlacklistRow0 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false;
                Label #BlacklistRow0Label { Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 24); }
                TextButton #BlacklistRow0Remove { Text: "X"; Anchor: (Width: 28, Height: 24); Style: @RemoveButtonStyle; }
              }
              Group #BlacklistRow1 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false;
                Label #BlacklistRow1Label { Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 24); }
                TextButton #BlacklistRow1Remove { Text: "X"; Anchor: (Width: 28, Height: 24); Style: @RemoveButtonStyle; }
              }
              Group #BlacklistRow2 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false;
                Label #BlacklistRow2Label { Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 24); }
                TextButton #BlacklistRow2Remove { Text: "X"; Anchor: (Width: 28, Height: 24); Style: @RemoveButtonStyle; }
              }
              Group #BlacklistRow3 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false;
                Label #BlacklistRow3Label { Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 24); }
                TextButton #BlacklistRow3Remove { Text: "X"; Anchor: (Width: 28, Height: 24); Style: @RemoveButtonStyle; }
              }
              Group #BlacklistRow4 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false;
                Label #BlacklistRow4Label { Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 24); }
                TextButton #BlacklistRow4Remove { Text: "X"; Anchor: (Width: 28, Height: 24); Style: @RemoveButtonStyle; }
              }
              Group #BlacklistPagination {
                LayoutMode: Left;
                Anchor: (Width: 160, Height: 22, Top: 4);
                Visible: false;
                TextButton #BlacklistFirst { Text: "<<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
                TextButton #BlacklistPrev { Text: "<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
                Label #BlacklistPageLabel { Text: "1/1"; Style: (TextColor: #5a6d82, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); FlexWeight: 1; }
                TextButton #BlacklistNext { Text: ">"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
                TextButton #BlacklistLast { Text: ">>"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
              }
              Label #BlacklistEmpty { Text: "No NPCs are blacklisted."; Style: (TextColor: #5a6d82, FontSize: 13); Anchor: (Height: 20, Top: 8); }
            }

            Group { FlexWeight: 1; }

            Group { LayoutMode: Left; Anchor: (Height: 36);
              TextButton #BlacklistClearAll { Text: "Clear Blacklist"; Anchor: (Width: 150, Height: 36); Style: @ResetButtonStyle; }
              Group { FlexWeight: 1; }
              Label #SaveMessageBlacklist { Text: ""; Style: (TextColor: #4ade80, FontSize: 13, RenderBold: true, VerticalAlignment: Center); Anchor: (Height: 36, Right: 10); Visible: false; }
              TextButton #SaveButtonBlacklist { Text: "Save"; Anchor: (Width: 140, Height: 36); Style: @SaveButtonStyle; }
            }
          }
        } // end #TabAdmin

        // Section 8: Disabled Tab
        Group #TabDisabled {
          LayoutMode: Top;
          FlexWeight: 1;
          Visible: false;
          Padding: (Left: 24, Right: 24, Top: 20, Bottom: 20);

