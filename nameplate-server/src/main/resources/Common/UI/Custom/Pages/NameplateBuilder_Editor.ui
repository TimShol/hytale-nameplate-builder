                  TextButton #PreviewTargetBtn7 { Text: ""; Anchor: (Height: 26); Style: @SubTabStyle; }
                  TextButton #PreviewTargetBtn7Active { Text: ""; Anchor: (Height: 26); Style: @SubTabActiveStyle; Visible: false; }
                }
              }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 42);

              Group #PreviewContainer {
                FlexWeight: 1;
                Anchor: (Height: 36);
                Background: (Color: #0a0f17);
                Padding: (Left: 14, Right: 14, Top: 2);
                LayoutMode: LeftScrolling;
                MouseWheelScrollBehaviour: HorizontalOnly;
                ScrollbarStyle: (Spacing: 2, Size: 3, Background: #2a2610, Handle: #8b7a3a, HoveredHandle: #a08840, DraggedHandle: #b89848);

                Label { Text: "Preview:"; Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, VerticalAlignment: Center); Anchor: (Width: 70, Height: 28); }
                Label #PreviewText { Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); Anchor: (Height: 28); }
              }

              $C.@SmallSecondaryTextButton #ClearChainButton {
                @Text = "Clear All";
                Anchor: (Width: 140, Height: 36, Left: 8);
                TooltipText: "Remove all segments from the chain";
                TextTooltipShowDelay: 0.3;
              }
            }

            Group { Anchor: (Height: 1, Top: 10, Bottom: 10); Background: (Color: #1a2840); }

            // Section 6a.3: Filter and available blocks
            $C.@TextField #FilterField {
              Anchor: (Width: 460, Height: 34, Bottom: 6);
              PlaceholderText: "Search for available blocks...";
              TooltipText: "Type to search available segments";
              TextTooltipShowDelay: 0.3;
            }

            Label {
              Text: "AVAILABLE BLOCKS";
              Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true);
              Anchor: (Height: 20, Bottom: 6);
            }

            Label #AvailEmpty {
              Text: "No blocks available";
              Style: (TextColor: #5a6d82, FontSize: 13);
              Anchor: (Height: 40, Bottom: 4);
              Visible: false;
            }

            // Section 6a.4: Available blocks container (TopScrolling with explicit rows of 4)
            Group #AvailSection {
              LayoutMode: TopScrolling;
              Anchor: (Height: 260);
