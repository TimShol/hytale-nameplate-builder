// NameplateBuilder — UI Template
// Section 1: Common import and Style Definitions

$C = "../Common.ui";

@CloseButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@RemoveButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@PaginationButtonStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 11, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 11, TextColor: #c8d6e5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 11, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@FormatButtonStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 11, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #2d6b3f, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 11, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@FormatButtonActiveStyle = TextButtonStyle(
  Default: (Background: #2d6b3f, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a8a50, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SaveButtonStyle = TextButtonStyle(
  Default: (Background: #2d6b3f, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a8a50, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@ResetButtonStyle = TextButtonStyle(
  Default: (Background: #8b5e2f, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #a07038, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #704b24, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SidebarNavStyle = TextButtonStyle(
  Default: (Background: #0d1520, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0a1119, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@NpcPickerBackdropStyle = TextButtonStyle(
  Default: (Background: #00000000, LabelStyle: (FontSize: 1, TextColor: #00000000)),
  Hovered: (Background: #00000000, LabelStyle: (FontSize: 1, TextColor: #00000000)),
  Pressed: (Background: #00000000, LabelStyle: (FontSize: 1, TextColor: #00000000))
);

@NpcPickerRowStyle = TextButtonStyle(
  Default: (Background: #141c26, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #1e2a3a, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #121a24, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@SidebarNavActiveStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@SubTabStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SubTabActiveStyle = TextButtonStyle(
  Default: (Background: #2d6b3f, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a8a50, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@ToggleOnStyle = TextButtonStyle(
  Default: (Background: #1a3a2a, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #244a3a, LabelStyle: (FontSize: 13, TextColor: #6aee9a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f2018, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@ToggleOffStyle = TextButtonStyle(
  Default: (Background: #1e2530, LabelStyle: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #252e3a, LabelStyle: (FontSize: 13, TextColor: #728898, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #171d26, LabelStyle: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

// Section 2: Root structure
$C.@PageOverlay {

  $C.@DecoratedContainer {
    Anchor: (Width: 1080, Height: 780);

    // Section 2.1: Title bar
    #Title {
      Group {
        LayoutMode: Left;

        Group {
          Anchor: (Width: 40, Height: 28);
        }

        Group {
          FlexWeight: 1;
          $C.@Title {
            @Text = "Nameplate Builder";
          }
        }

        Label #VersionLabel {
          Style: (FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Width: 80, Height: 28);
          Text: "";
        }

        Group {
          Anchor: (Width: 40, Height: 28);
          TextButton #CloseButton {
            Text: "X";
            Anchor: (Width: 32, Height: 28);
            Style: @CloseButtonStyle;
            TooltipText: "Close the Nameplate Builder";
            TextTooltipShowDelay: 0.3;
          }
        }
      }
    }

    // Section 2.2: Content area (sidebar + main)
    #Content {
      LayoutMode: Left;
      Padding: (Left: 0, Right: 0, Top: 0, Bottom: 0);

      // Section 3: Sidebar
      Group #Sidebar {
        Anchor: (Width: 250);
        Background: (Color: #0a1119);
        LayoutMode: Top;
        Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);

        Label {
          Text: "GENERAL";
          Style: (TextColor: #5a6d82, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 2);
          Anchor: (Height: 18, Bottom: 6);
        }

        Group #NavGeneralGroup { Anchor: (Height: 28, Bottom: 3);
          TextButton #NavGeneral { Text: "Settings"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); TooltipText: "General settings: enable/disable, display options"; TextTooltipShowDelay: 0.3; }
          TextButton #NavGeneralActive { Text: "Settings"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; TooltipText: "General settings: enable/disable, display options"; TextTooltipShowDelay: 0.3; }
        }

        Group #NavDisabledGroup { Anchor: (Height: 28, Bottom: 3);
          TextButton #NavDisabled { Text: "Disabled Segments"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); TooltipText: "View segments disabled by the server admin"; TextTooltipShowDelay: 0.3; }
          TextButton #NavDisabledActive { Text: "Disabled Segments"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; TooltipText: "View segments disabled by the server admin"; TextTooltipShowDelay: 0.3; }
        }

        Group { Anchor: (Height: 1, Top: 8, Bottom: 10); Background: (Color: #1a2840); }

        Label #NameplatesHeader {
          Text: "NAMEPLATES";
          Style: (TextColor: #5a6d82, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 2);
          Anchor: (Height: 18, Bottom: 6);
        }

        Group #NavNpcsGroup { Anchor: (Height: 28, Bottom: 3);
          TextButton #NavNpcs { Text: "NPCs"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); TooltipText: "Configure NPC nameplate segments and ordering"; TextTooltipShowDelay: 0.3; }
          TextButton #NavNpcsActive { Text: "NPCs"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; TooltipText: "Configure NPC nameplate segments and ordering"; TextTooltipShowDelay: 0.3; }
        }

        Group #NavPlayersGroup { Anchor: (Height: 28, Bottom: 3);
          TextButton #NavPlayers { Text: "Players"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); TooltipText: "Configure player nameplate segments and ordering"; TextTooltipShowDelay: 0.3; }
          TextButton #NavPlayersActive { Text: "Players"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; TooltipText: "Configure player nameplate segments and ordering"; TextTooltipShowDelay: 0.3; }
        }

        Group { FlexWeight: 1; }

        Group #AdminSection {
          LayoutMode: Top;
          Visible: false;

          Group { Anchor: (Height: 1, Bottom: 10); Background: (Color: #1a2840); }

          Label {
            Text: "ADMIN";
            Style: (TextColor: #5a6d82, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 2);
            Anchor: (Height: 18, Bottom: 6);
          }

          Group #NavAdminNpcsGroup { Anchor: (Height: 28, Bottom: 3);
            TextButton #NavAdminNpcs { Text: "NPCs"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); TooltipText: "Set the admin-enforced NPC nameplate chain order"; TextTooltipShowDelay: 0.3; }
            TextButton #NavAdminNpcsActive { Text: "NPCs"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; TooltipText: "Set the admin-enforced NPC nameplate chain order"; TextTooltipShowDelay: 0.3; }
          }

          Group #NavAdminPlayersGroup2 { Anchor: (Height: 28, Bottom: 3);
            TextButton #NavAdminPlayers { Text: "Players"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); TooltipText: "Set the admin-enforced player nameplate chain order"; TextTooltipShowDelay: 0.3; }
            TextButton #NavAdminPlayersActive { Text: "Players"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; TooltipText: "Set the admin-enforced player nameplate chain order"; TextTooltipShowDelay: 0.3; }
          }

          Group { Anchor: (Height: 1, Top: 6, Bottom: 6); Background: (Color: #1a2840); }

          Group #NavAdminConfigGroup { Anchor: (Height: 28, Bottom: 3);
            TextButton #NavAdminConfig { Text: "Configuration"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); TooltipText: "Server-wide nameplate configuration and management"; TextTooltipShowDelay: 0.3; }
            TextButton #NavAdminConfigActive { Text: "Configuration"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; TooltipText: "Server-wide nameplate configuration and management"; TextTooltipShowDelay: 0.3; }
          }
        }
      }

      // Section 4: Main Content
      Group #MainContent {
        FlexWeight: 1;
        Background: (Color: #141c26);
        LayoutMode: Top;
        Padding: (Left: 24, Right: 16, Top: 8, Bottom: 16);

        // Section 5: General Tab
        Group #TabGeneral {
          LayoutMode: Top;
          FlexWeight: 1;
          Visible: false;
          Padding: (Top: 12);

          Label {
            Text: "GENERAL";
            Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
            Anchor: (Height: 24, Bottom: 16);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 28, Bottom: 8);
            Padding: (Left: 16, Right: 16);

            Label #EnableToggleLabel {
              Text: "Enable Nameplates";
              Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
              Anchor: (Width: 300, Height: 28);
            }

            ToggleButton #EnableToggle {
              Anchor: (Width: 50, Height: 28);
              IsChecked: false;
              Background: (Color: #1e2530);
              TooltipText: "Enable or disable all nameplates";
              TextTooltipShowDelay: 0.3;
              Label #EnableToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
            }
          }

          Label #AllDisabledNotice {
            Text: "All segments disabled by admin. Nameplates are inactive.";
            Style: (TextColor: #c94c4c, FontSize: 13, RenderBold: true);
            Anchor: (Height: 20, Bottom: 4);
            Visible: false;
          }

          Group {
            Anchor: (Height: 2, Top: 3, Bottom: 17);
            Background: (Color: #1a2840);
          }

          Label {
            Text: "DISPLAY";
            Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
            Anchor: (Height: 20, Bottom: 12);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 28, Bottom: 8);
            Padding: (Left: 16, Right: 16);

            Label {
              Text: "Only Show NPC Nameplates When Looking";
              Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
              Anchor: (Width: 300, Height: 28);
            }

            ToggleButton #LookToggle {
              Anchor: (Width: 50, Height: 28);
              IsChecked: false;
              Background: (Color: #1e2530);
              TooltipText: "Only show NPC nameplates when looking at them";
              TextTooltipShowDelay: 0.3;
              Label #LookToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 28, Bottom: 8);
            Padding: (Left: 16, Right: 16);

            Label #WelcomeToggleLabel {
              Text: "Show Welcome Message";
              Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
              Anchor: (Width: 300, Height: 28);
            }

            ToggleButton #WelcomeToggle {
              Anchor: (Width: 50, Height: 28);
              IsChecked: false;
              Background: (Color: #1e2530);
              TooltipText: "Show a welcome message when joining the server";
              TextTooltipShowDelay: 0.3;
              Label #WelcomeToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
            }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 28, Bottom: 8);
            Padding: (Left: 16, Right: 16);

            Label {
              Text: "Vertical Offset";
              Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
              Anchor: (Width: 200, Height: 28);
            }

            FloatSliderNumberField #OffsetSlider {
              Anchor: (Width: 300, Height: 28);
              Min: -5.0;
              Max: 5.0;
              Step: 0.1;
              Value: 0.0;
              NumberFieldMaxDecimalPlaces: 1;
              NumberFieldDefaultValue: 0.0;
              SliderStyle: (Background: #0a1119, Fill: #1a2840, Handle: #c9a84c, HandleWidth: 12, HandleHeight: 18);
              NumberFieldStyle: (FontSize: 13, TextColor: #c8d6e5);
              NumberFieldContainerAnchor: (Width: 50, Height: 28);
              TooltipText: "Adjust nameplate vertical position (-5.0 to 5.0)";
              TextTooltipShowDelay: 0.3;
            }
          }

          $C.@TextField #OffsetField {
            Anchor: (Width: 0, Height: 0);
            Visible: false;
          }

          Group {
            FlexWeight: 1;
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 36);

            Group { FlexWeight: 1; }

            Label #SaveMessageGeneral {
              Text: "";
              Style: (TextColor: #4ade80, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
              Anchor: (Height: 36, Right: 10);
              Visible: false;
            }

            TextButton #SaveButtonGeneral {
              Text: "Save";
              Anchor: (Width: 140, Height: 36);
              Style: @SaveButtonStyle;
              TooltipText: "Save your general settings";
              TextTooltipShowDelay: 0.3;
            }
          }
        }

        // Section 6: Editor Tab
        Group #TabEditor {
          LayoutMode: Top;
          FlexWeight: 1;
          Visible: true;

          // Section 6.0: Chain sub-tab bar
          Group #ChainSubTabBar {
            LayoutMode: Left;
            Anchor: (Height: 38);
            Padding: (Left: 24, Right: 24, Top: 4, Bottom: 4);

            Group { FlexWeight: 1; Anchor: (Height: 30);
              TextButton #SubTabChain { Text: "Chain"; Anchor: (Height: 30); Style: @SubTabStyle; }
              TextButton #SubTabChainActive { Text: "Chain"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; }
            }
            Group { Anchor: (Width: 4, Height: 30); }
            Group { FlexWeight: 1; Anchor: (Height: 30);
              TextButton #SubTabSettings { Text: "Settings"; Anchor: (Height: 30); Style: @SubTabStyle; }
              TextButton #SubTabSettingsActive { Text: "Settings"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; }
            }
          }

          // Section 6a: Editor Content (chain sub-tab)
          Group #EditorContent {
            LayoutMode: TopScrolling;
            FlexWeight: 1;
            KeepScrollPosition: true;
            ScrollbarStyle: (Spacing: 2, Size: 4, Background: #2a2610, Handle: #8b7a3a, HoveredHandle: #a08840, DraggedHandle: #b89848);

            Group #LockChainBar { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8); Visible: false;
              Label { Text: "Lock Chain"; Style: (TextColor: #c8d6e5, FontSize: 14, RenderBold: true, VerticalAlignment: Center); Anchor: (Width: 120, Height: 34); }
              ToggleButton #LockChainToggle {
                Anchor: (Width: 50, Height: 28);
                IsChecked: false;
                Background: (Color: #1e2530);
                TooltipText: "Lock the chain order for all players";
                TextTooltipShowDelay: 0.3;
                Label #LockChainToggleText { Style: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "OFF"; }
              }
              Group { Anchor: (Width: 14); }
              Label #LockChainHint { Text: ""; Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center); FlexWeight: 1; }
            }

            Label #ChainLockedNotice {
              Text: "Chain locked by the server admin.";
              Style: (TextColor: #c94c4c, FontSize: 14, RenderBold: true);
              Anchor: (Height: 24, Bottom: 8);
              Visible: false;
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 20, Bottom: 4);

              Label #EditorTitle {
                Text: "YOUR NPC NAMEPLATE";
                Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
                Anchor: (Height: 20);
              }

              Label {
                Text: "  (read left to right)";
                Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center);
                Anchor: (Height: 20);
              }
            }

            Label #AdminChainDisabledNotice {
              Text: "";
              Style: (TextColor: #c94c4c, FontSize: 13, RenderBold: true);
              Anchor: (Height: 40, Bottom: 8);
              Visible: false;
            }

            Label #NonIntegratedInfo {
              Text: "";
              Style: (TextColor: #7a8a9e, FontSize: 13);
              Anchor: (Height: 44, Bottom: 8);
              Visible: false;
            }

            Label #ChainEmpty {
              Text: "No blocks added yet";
              Style: (TextColor: #5a6d82, FontSize: 13);
              Anchor: (Height: 126, Bottom: 4);
              Visible: true;
            }

            // Section 6a.1: Chain Strip
            ReorderableList #ChainStrip {
              LayoutMode: Left;
              Anchor: (Height: 136);
              ContentHeight: 122;
              MouseWheelScrollBehaviour: HorizontalOnly;
              ScrollbarStyle: (Spacing: 4, Size: 6, Background: #2a2610, Handle: #8b7a3a, HoveredHandle: #a08840, DraggedHandle: #b89848);
              KeepScrollPosition: true;
              Overscroll: true;
              DropIndicatorAnchor: (Width: 4);
              DropIndicatorBackground: #4ade80;

  Group #ChainSlot0 { LayoutMode: Left; Anchor: (Height: 122); Visible: false;
    ReorderableListGrip #ChainBlock0 {
      TooltipText: "Drag to reorder";
      TextTooltipShowDelay: 0.5;
      Anchor: (Width: 176, Height: 122);
      Background: (Color: #1a2840);
      LayoutMode: Top;
      Padding: (Left: 10, Right: 10, Top: 6, Bottom: 4);

      Group { LayoutMode: Left; Anchor: (Height: 20);
        Label #ChainBlock0Label { Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 20); }
        TextButton #ChainBlock0Remove { Text: "X"; Anchor: (Width: 22, Height: 18); Style: @RemoveButtonStyle; TooltipText: "Remove segment from chain"; TextTooltipShowDelay: 0.3; }
      }
      Label #ChainBlock0Sub { Style: (FontSize: 11, TextColor: #96a9be); Anchor: (Height: 16); }
      Label #ChainBlock0Author { Style: (FontSize: 11, TextColor: #5a6d82); Anchor: (Height: 14); }
      Group { FlexWeight: 1; }
      Group { LayoutMode: Left; Anchor: (Height: 25);
        $C.@SmallSecondaryTextButton #ChainBlock0Left { @Text = "<"; Anchor: (Width: 25, Height: 25); TooltipText: "Move segment left"; TextTooltipShowDelay: 0.3; }
        Group { FlexWeight: 1; }
        $C.@SmallSecondaryTextButton #ChainBlock0Right { @Text = ">"; Anchor: (Width: 25, Height: 25); TooltipText: "Move segment right"; TextTooltipShowDelay: 0.3; }
      }
      Group { Anchor: (Height: 4); }
      Group #ChainBlock0BottomRow { LayoutMode: Left; Anchor: (Height: 18);
        Group #ChainBlock0ExampleBar { FlexWeight: 1; Anchor: (Height: 18); Background: (Color: #111a28); Padding: (Left: 4, Right: 4);
          Label #ChainBlock0Example { Style: (FontSize: 11, TextColor: #6b7d93, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 18); }
        }
        TextButton #ChainBlock0Format { Text: "Format"; FlexWeight: 1; Anchor: (Height: 18); Style: @FormatButtonStyle; Visible: false; TooltipText: "Change display format"; TextTooltipShowDelay: 0.3; }
      }
    }
    $C.@SmallSecondaryTextButton #ChainSep0 { @Text = "-"; Anchor: (Width: 28, Height: 122); Visible: false; TooltipText: "Edit separator"; TextTooltipShowDelay: 0.3; }
  }

  Group #ChainSlot1 { LayoutMode: Left; Anchor: (Height: 122); Visible: false;
    ReorderableListGrip #ChainBlock1 {
      TooltipText: "Drag to reorder";
      TextTooltipShowDelay: 0.5;
      Anchor: (Width: 176, Height: 122);
      Background: (Color: #1a2840);
      LayoutMode: Top;
      Padding: (Left: 10, Right: 10, Top: 6, Bottom: 4);

      Group { LayoutMode: Left; Anchor: (Height: 20);
