  Group #SepPopupOverlay {
    Anchor: (Width: 1080, Height: 780);
    Background: (Color: #00000080);
    Visible: false;

    Group {
      Anchor: (Width: 320, Height: 180);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

      Label {
        Text: "Edit Separator";
        Style: (TextColor: #96a9be, FontSize: 16, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Height: 26, Bottom: 16);
      }

      Label {
        Text: "Enter the text to display between these two blocks:";
        Style: (TextColor: #5a6d82, FontSize: 14, HorizontalAlignment: Center);
        Anchor: (Height: 20, Bottom: 12);
      }

      $C.@TextField #SepTextField {
        Anchor: (Height: 34, Bottom: 16);
        PlaceholderText: "Enter your seperator...";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 36);

        Group { FlexWeight: 1; }

        TextButton #SepCancel {
          Text: "Cancel";
          Anchor: (Width: 100, Height: 36, Right: 10);
          Style: @PaginationButtonStyle;
        }

        TextButton #SepConfirm {
          Text: "Confirm";
          Anchor: (Width: 100, Height: 36);
          Style: @SaveButtonStyle;
        }
      }
    }
  }

  Group #VariantPopupOverlay {
    Anchor: (Width: 1080, Height: 780);
    Background: (Color: #00000080);
    Visible: false;

    Group {
      Anchor: (Width: 320, Height: 520);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

      Label {
        Text: "Select Format";
        Style: (TextColor: #96a9be, FontSize: 16, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Height: 26, Bottom: 12);
      }

      Label #VariantSegmentName {
        Text: "";
        Style: (TextColor: #5a6d82, FontSize: 14, HorizontalAlignment: Center);
        Anchor: (Height: 20, Bottom: 12);
      }

      TextButton #Variant0 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }
      TextButton #Variant1 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }
      TextButton #Variant2 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }
      TextButton #Variant3 { Text: ""; Anchor: (Height: 32, Bottom: 4); Style: @PaginationButtonStyle; Visible: false; }

      Group #PrefixSuffixSection {
        LayoutMode: Top;
        Visible: false;

        Group {
          Anchor: (Height: 1, Bottom: 8, Top: 8);
          Background: (Color: #2a3a4e);
        }

        Label {
          Text: "Prefix / Suffix";
          Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true, HorizontalAlignment: Center);
          Anchor: (Height: 22, Bottom: 6);
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28, Bottom: 4);

          Label {
            Text: "Before:";
            Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center);
            Anchor: (Width: 56, Height: 28);
          }

          $C.@TextField #PrefixField {
            Value: "";
            Anchor: (Height: 28);
            FlexWeight: 1;
            PlaceholderText: "e.g. [";
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28, Bottom: 4);

          Label {
            Text: "After:";
            Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center);
            Anchor: (Width: 56, Height: 28);
          }

          $C.@TextField #SuffixField {
            Value: "";
            Anchor: (Height: 28);
            FlexWeight: 1;
            PlaceholderText: "e.g. ]";
          }
        }
      }

      Group #BarCustomSection {
        LayoutMode: Top;
        Visible: false;

        Group {
          Anchor: (Height: 1, Bottom: 8, Top: 8);
          Background: (Color: #2a3a4e);
        }

        Label {
          Text: "Bar Style";
          Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true, HorizontalAlignment: Center);
          Anchor: (Height: 22, Bottom: 6);
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28, Bottom: 4);

          Label {
            Text: "Empty:";
            Style: (TextColor: #5a6d82, FontSize: 13, VerticalAlignment: Center);
            Anchor: (Width: 56, Height: 28);
          }

          $C.@TextField #BarEmptyField {
            Value: "";
            Anchor: (Height: 28);
            FlexWeight: 1;
            PlaceholderText: "-";
          }
        }
      }

      Group { FlexWeight: 1; }

      TextButton #VariantCancel {
        Text: "Cancel";
        Anchor: (Height: 36, Bottom: 4);
        Style: @PaginationButtonStyle;
      }


      TextButton #VariantConfirm {
        Text: "Confirm";
        Anchor: (Height: 36);
        Style: @SaveButtonStyle;
      }
    }
  }

  Group #NpcPickerPopup {
    Anchor: (Width: 1080, Height: 780);
    Background: (Color: #00000080);
    Visible: false;

    TextButton #NpcPickerBackdrop { Text: ""; Anchor: (Width: 1080, Height: 780); Style: @NpcPickerBackdropStyle; }

    Group {
      Anchor: (Width: 420, Height: 620);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 18, Right: 18, Top: 14, Bottom: 14);

      Label { Text: "Select NPC"; Style: (FontSize: 16, TextColor: #c8d6e5, RenderBold: true); Anchor: (Height: 26, Bottom: 8); }

      Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 6);
        Label { Text: "Filter:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 50, Height: 28); }
        $C.@TextField #NpcPickerFilter { Anchor: (Height: 28); Style: (FontSize: 13, TextColor: #c8d6e5); FlexWeight: 1; }
      }

      Group #NpcPickerRows {
        LayoutMode: Top;

        Group #NpcPickerRow0 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn0 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow1 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn1 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow2 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn2 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow3 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn3 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow4 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn4 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow5 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn5 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow6 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn6 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow7 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn7 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow8 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn8 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
        Group #NpcPickerRow9 { Anchor: (Height: 26, Bottom: 2); Visible: false;
          TextButton #NpcPickerRowBtn9 { Text: ""; Anchor: (Height: 26); Style: @NpcPickerRowStyle; }
        }
      }

      Label #NpcPickerEmpty { Text: "No NPCs match filter."; Style: (FontSize: 13, TextColor: #5a6d82); Anchor: (Height: 18); Visible: false; }

      Group #NpcPickerPagination { LayoutMode: Left; Anchor: (Height: 22, Top: 4); Visible: false;
        TextButton #NpcPickerFirstPage { Text: "<<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
        TextButton #NpcPickerPrevPage { Text: "<"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
        Label #NpcPickerPageInfo { Text: "1/1"; Style: (TextColor: #5a6d82, FontSize: 11, HorizontalAlignment: Center, VerticalAlignment: Center); FlexWeight: 1; }
        TextButton #NpcPickerNextPage { Text: ">"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
        TextButton #NpcPickerLastPage { Text: ">>"; Style: @PaginationButtonStyle; Anchor: (Width: 26, Height: 22); }
      }

      Group { FlexWeight: 1; }

      Group { LayoutMode: Left; Anchor: (Height: 22, Bottom: 6);
        Label { Text: "Selected: "; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); }
        Label #NpcPickerSelectedLabel { Text: "None"; Style: (FontSize: 13, TextColor: #4ade80, VerticalAlignment: Center); }
      }

      Group { LayoutMode: Left; Anchor: (Height: 34);
        TextButton #NpcPickerCancel { Text: "Cancel"; Anchor: (Width: 140, Height: 30); Style: @ResetButtonStyle; }
        Group { FlexWeight: 1; }
        TextButton #NpcPickerAddAllFiltered { Text: "Add All Filtered"; Anchor: (Width: 160, Height: 30); Style: @SaveButtonStyle; Visible: false; }
        Group { Anchor: (Width: 8); }
        TextButton #NpcPickerAdd { Text: "Add to Blacklist"; Anchor: (Width: 170, Height: 30); Style: @SaveButtonStyle; Visible: false; }
      }
    }
  }
}
