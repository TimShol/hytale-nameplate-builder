              TextButton #AdminNpcChainToggleOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; }
            }

            Label {
              Text: "When disabled, no NPC nameplates are shown for any entity.";
              Style: (TextColor: #5a6d82, FontSize: 11);
              Anchor: (Height: 20, Bottom: 8);
