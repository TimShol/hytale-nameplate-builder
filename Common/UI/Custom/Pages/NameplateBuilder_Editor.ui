          Group #AdminSettingsContent {
            LayoutMode: TopScrolling;
            ScrollbarStyle: (Spacing: 8, Size: 4, Background: #1a2840, Handle: #2a3d5a, HoveredHandle: #3a5070, DraggedHandle: #4a6080);
            FlexWeight: 1;
            Visible: false;
            Padding: (Left: 24, Right: 16, Top: 12);

            Label {
              Text: "ADMIN SETTINGS";
              Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
              Anchor: (Height: 24, Bottom: 4);
            }

            Label {
              Text: "Configure server-wide nameplate settings.";
              Style: (TextColor: #5a6d82, FontSize: 11);
              Anchor: (Height: 16, Bottom: 12);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 36, Bottom: 10);
              Label {
                Text: "Server Name:";
                Style: (TextColor: #96a9be, FontSize: 13, VerticalAlignment: Center);
                Anchor: (Width: 130, Height: 36);
              }
              $C.@TextField #AdminServerNameField {
                Anchor: (Width: 330, Height: 34);
                PlaceholderText: "NameplateBuilder";
              }
            }

            Label {
              Text: "Shown in the welcome message when players join. Leave blank for \"NameplateBuilder\".";
              Style: (TextColor: #5a6d82, FontSize: 11);
              Anchor: (Height: 20, Bottom: 20);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 8);

              Label {
                Text: "Show Welcome Messages";
                Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
                Anchor: (Width: 300, Height: 28);
              }

              TextButton #AdminWelcomeToggleOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; }
              TextButton #AdminWelcomeToggleOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; }
            }

            Label {
              Text: "When enabled, all players see a welcome message on join. Players can still individually disable it.";
              Style: (TextColor: #5a6d82, FontSize: 11);
              Anchor: (Height: 20, Bottom: 20);
            }

            Group {
              Anchor: (Height: 1, Bottom: 14);
              Background: (Color: #1a2840);
            }

            Label {
              Text: "KILLSWITCHES";
              Style: (TextColor: #96a9be, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
              Anchor: (Height: 20, Bottom: 8);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 4);

              Label {
                Text: "Master Enable";
                Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
                Anchor: (Width: 300, Height: 28);
              }

              TextButton #AdminMasterToggleOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; }
              TextButton #AdminMasterToggleOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; }
            }

            Label {
              Text: "When disabled, NameplateBuilder does nothing. No nameplates are created or updated.";
              Style: (TextColor: #5a6d82, FontSize: 11);
              Anchor: (Height: 20, Bottom: 8);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 4);

              Label {
                Text: "Player Nameplates";
                Style: (TextColor: #c8d6e5, FontSize: 13, VerticalAlignment: Center);
                Anchor: (Width: 300, Height: 28);
              }

              TextButton #AdminPlayerChainToggleOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; }
              TextButton #AdminPlayerChainToggleOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; }
            }

            Label {
              Text: "When disabled, no player nameplates are shown for any player.";
              Style: (TextColor: #5a6d82, FontSize: 11);
              Anchor: (Height: 20, Bottom: 8);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 4);

