          }

          Group #DisabledPagination {
            LayoutMode: Left;
            Anchor: (Height: 36, Top: 8);

            Group { FlexWeight: 1; }

            TextButton #PrevDisabled {
              Text: "<";
              Anchor: (Width: 36, Height: 36, Right: 8);
              Style: @PaginationButtonStyle;
              Visible: false;
            }

            Label #DisabledPageLabel {
              Text: "";
              Style: (TextColor: #5a6d82, FontSize: 13, HorizontalAlignment: Center, VerticalAlignment: Center);
